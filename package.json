{
  "name": "@trustlayer/plugin-elizaos",
  "description": "TrustLayer reputation scoring plugin for ElizaOS — pre-transaction trust checks for AI agents",
  "version": "0.2.0",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "packageType": "plugin",
  "platform": "node",
  "license": "MIT",
  "author": "goatgaucho",
  "repository": {
    "type": "git",
    "url": "https://github.com/goatgaucho/elizaos-plugin-trustlayer"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      }
    }
  },
  "dependencies": {
    "@elizaos/core": ">=1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "bun run build.ts",
    "dev": "elizaos dev"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "TRUSTLAYER_API_URL": {
        "type": "string",
        "description": "TrustLayer API base URL (default: https://api.thetrustlayer.xyz)"
      },
      "TRUSTLAYER_MIN_SCORE": {
        "type": "number",
        "description": "Minimum trust score to consider an agent safe (default: 64)"
      }
    }
  }
}
